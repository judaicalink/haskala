@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

jl:haskala a owl:Ontology ;
    dcterms:created "2026-06-03"^^xsd:date ;
    dcterms:description "Schema vocabulary for the Haskala bibliography dataset. Generated from the Django models that drive the public site; regenerated by the dump_ontology management command."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:publisher "JudaicaLink / Haskala Project" ;
    dcterms:title "Haskala Bibliography Ontology"@en .

hs:FormatFilteredHTML a rdfs:Datatype ;
    rdfs:label "format: filtered HTML"@en ;
    rdfs:subClassOf xsd:string .

hs:FormatFullHTML a rdfs:Datatype ;
    rdfs:label "format: full HTML"@en ;
    rdfs:subClassOf xsd:string .

hs:FormatJSON a rdfs:Datatype ;
    rdfs:label "format: JSON"@en ;
    rdfs:subClassOf xsd:string .

hs:FormatMarkdown a rdfs:Datatype ;
    rdfs:label "format: Markdown"@en ;
    rdfs:subClassOf xsd:string .

hs:FormatNone a rdfs:Datatype ;
    rdfs:label "format: none"@en ;
    rdfs:subClassOf xsd:string .

hs:FormatText a rdfs:Datatype ;
    rdfs:label "format: text"@en ;
    rdfs:subClassOf xsd:string .

hs:FormatUnknown a rdfs:Datatype ;
    rdfs:label "format: unknown"@en ;
    rdfs:subClassOf xsd:string .

hs:FormatXML a rdfs:Datatype ;
    rdfs:label "format: XML"@en ;
    rdfs:subClassOf xsd:string .

hs:alignment a owl:ObjectProperty ;
    rdfs:label "alignment"@en ;
    rdfs:domain hs:Book ;
